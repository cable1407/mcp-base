{
  "name": "mcp-base",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "Shared TypeScript foundation for Model Context Protocol (MCP) servers \u2014 OAuth + discovery + consent + CORS + access logging in one reusable base.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cable1407/mcp-base.git"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check src test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
